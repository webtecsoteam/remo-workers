# =============================================
# RemoWorkers - Environment Configuration
# =============================================
# Copy this file to .env and update the values

# Application Settings
APP_NAME=RemoWorkers
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/upwork/upwork%20project

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=remoworkers
DB_USERNAME=root
DB_PASSWORD=

# Mail Configuration
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@remoworkers.com
MAIL_FROM_NAME=RemoWorkers

# Session Configuration
SESSION_LIFETIME=120

# Route Prefixes
ROUTE_HOME=/
ROUTE_CLIENT=/client
ROUTE_FREELANCER=/remoworkers-dashboard
