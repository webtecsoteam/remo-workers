# =============================================
# RemoWorkers - Environment Configuration
# =============================================
# Copy this file to .env and update the values

# Application Settings
APP_NAME=RemoWorkers
APP_ENV=development
APP_DEBUG=true
# Site URL (fallback for CLI/cron). Web requests use the current host automatically.
# Use your canonical domain; pick either www or non-www and redirect the other in hosting.
APP_URL=http://localhost/remowork/
# Optional absolute path to the external homepage template file.
# Example: /home/username/public_html/free/index.php
HOMEPAGE_TEMPLATE_PATH=
# Enable temporary logging of template path resolution in PHP error logs.
HOMEPAGE_TEMPLATE_DEBUG=false

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=remoworkers
DB_USERNAME=root
DB_PASSWORD=

# Mail Configuration (primary — Hostinger / default Mailer::send())
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=support@remoworkers.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=support@remoworkers.com
MAIL_FROM_NAME=RemoWorkers

# Brevo SMTP (additional — Mailer::sendViaBrevo())
MAIL_BREVO_HOST=smtp-relay.brevo.com
MAIL_BREVO_PORT=587
MAIL_BREVO_USERNAME=your-id@smtp-brevo.com
MAIL_BREVO_PASSWORD=your-brevo-smtp-key
MAIL_BREVO_FROM_ADDRESS=support@remoworkers.com
MAIL_BREVO_FROM_NAME=RemoWorkers

# Session Configuration
SESSION_LIFETIME=120

# Route Prefixes
ROUTE_HOME=/
ROUTE_CLIENT=/client
ROUTE_FREELANCER=/remoworkers-dashboard

# Paystack Configuration
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# CCPayment (crypto deposits / webhooks)
CCPAYMENT_API_KEY=
CCPAYMENT_SECRET=
# CCPayment chain symbol (Tron USDT TRC20 = TRX per their API; Polygon = POLYGON)
CCPAYMENT_CHAIN=TRX
CCPAYMENT_DEPOSIT_ADDRESS_URL=https://ccpayment.com/ccpayment/v2/getOrCreateAppDepositAddress
CCPAYMENT_DEPOSIT_RECORD_URL=https://ccpayment.com/ccpayment/v2/getAppDepositRecord
# Crypto withdrawals (freelancer earnings → on-chain USDT)
CCPAYMENT_WITHDRAW_URL=https://ccpayment.com/ccpayment/v2/applyAppWithdrawToNetwork
CCPAYMENT_WITHDRAW_RECORD_URL=https://ccpayment.com/ccpayment/v2/getAppWithdrawRecord
CCPAYMENT_WITHDRAW_COIN_ID=1280
CCPAYMENT_WITHDRAW_CHAIN=POLYGON
# Withdrawals always send merchantPayNetworkFee: false (user pays network fee)
# Allow TETH etc. on testnet when APP_ENV=development
CCPAYMENT_ALLOW_TEST_COINS=false
# USD shortfall allowed vs order total (e.g. 0.05 = 5 cents)
CCPAYMENT_AMOUNT_TOLERANCE=0.01
